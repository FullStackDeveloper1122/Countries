* {
  box-sizing: border-box;
}

body {
  --background-color: white;
  --text-color: black;
  --element-color: white;
  margin: 0;
  font-family: Nunito, sans-serif;
}

main, header {
  background-color: var(--background-color);
  color: var(--text-color);
}

main.dark, header.dark {
  --background-color: #202c37;
  --text-color: white;
  --element-color: #2b3945;
}

main {
  min-height: calc(100vh - 68px);
  padding: 24px;
}

.header-container {
  background-color: var(--element-color);
  z-index: 1;
  padding-inline: 12px;
  position: sticky;
  top: 0;
  box-shadow: 0 2px 4px 1px #0000001a;
}

.header-content {
  justify-content: space-between;
  align-items: center;
  max-width: 1100px;
  margin-inline: auto;
  display: flex;
}

a {
  color: inherit;
  text-decoration-line: none;
}

.title {
  font-weight: 800;
}

.countries-container {
  margin-inline: auto;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 64px;
  max-width: 1100px;
  margin-top: 16px;
  display: flex;
}

.country-card {
  background-color: var(--element-color);
  border-radius: 6px;
  width: 250px;
  padding-bottom: 16px;
  transition: all .2s ease-in-out;
  display: inline-block;
  overflow: hidden;
  box-shadow: 0 2px 4px 1px #0000001a;
}

.country-card:hover {
  transform: scale(1.05);
  box-shadow: 0 2px 12px 1px #0000001a;
}

.flag-container {
  height: 160px;
  overflow: hidden;
}

.flag-container img {
  object-fit: cover;
  width: 100%;
  height: 100%;
}

.card-title {
  margin-block: 14px;
  font-size: 18px;
}

.card-text {
  padding-inline: 12px;
}

.card-text p {
  margin-block: 8px;
}

.search-filter-container {
  margin-top: 16px;
  margin-bottom: 48px;
  justify-content: space-between;
  max-width: 1100px;
  margin-inline: auto;
  display: flex;
}

.search-filter {
  color: gray;
  background-color: var(--element-color);
  border-radius: 4px;
  width: 100%;
  max-width: 350px;
  padding-left: 24px;
  overflow: hidden;
  box-shadow: 0 2px 12px 1px #0000001a;
}

.search-filter input {
  background-color: inherit;
  width: 90%;
  color: var(--text-color);
  border: none;
  outline: none;
  padding: 12px 16px;
}

.theme-changer {
  cursor: pointer;
}

.filter-by-Region {
  background-color: var(--element-color);
  width: 250px;
  color: var(--text-color);
  border: none;
  border-radius: 4px;
  outline: none;
  padding: 16px;
  box-shadow: 0 2px 12px 1px #0000001a;
}

@media (width <= 640px) {
  .countries-container {
    justify-content: center;
  }

  .title {
    font-size: 16px;
  }

  .header-content p {
    font-size: 12px;
  }

  .search-filter-container {
    flex-direction: column;
    gap: 16px;
  }
}

main .shimmer-card {
  --shimmer-color: #c7c7c7;
}

main.dark .shimmer-card {
  --shimmer-color: #445869;
}

.shimmer-card {
  background-color: var(--elements-color);
  height: 338px;
}

.shimmer-card .flag-container {
  background-color: var(--shimmer-color);
  height: 160px;
}

.shimmer-card .card-title {
  background-color: var(--shimmer-color);
  border-radius: 4px;
  height: 32px;
}

.shimmer-card p {
  background-color: var(--shimmer-color);
  border-radius: 4px;
  height: 22px;
}

.shimmer-card p:last-child {
  width: 50%;
}

.back-button {
  border-radius: 6px;
  padding: 8px 24px;
  box-shadow: 0 2px 12px 1px #0000001a;
}

.country-details {
  align-items: center;
  gap: 64px;
  margin-top: 64px;
  display: flex;
}

.country-details img {
  width: 40%;
}

.detail-text {
  flex-flow: column wrap;
  gap: 12px 64px;
  max-height: 180px;
  display: flex;
}

.detail-text p {
  margin: 0;
}

.border-countries {
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 4px;
  margin-top: 48px;
  display: flex;
}

.border-countries a {
  border-radius: 6px;
  margin-inline: 3px;
  padding: 4px 10px;
  font-size: 12px;
  box-shadow: 0 2px 12px 1px #0000001a;
}

@media (width <= 870px) {
  .country-details {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    margin-top: 32px;
  }

  .detail-text {
    max-height: unset;
  }

  .country-details img {
    width: 100%;
    max-width: 400px;
  }
}
/*# sourceMappingURL=CountriesProject Completed.75cbc9c6.css.map */
